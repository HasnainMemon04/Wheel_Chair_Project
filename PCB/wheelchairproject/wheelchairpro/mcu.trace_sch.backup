# ── Nets ─────────────────────────────────────────────────────────────────────
net V3V3 GND ESP_EN
net BOOT_BTN IO0_NET IO2_NET IO12_NET IO15_NET
net MODEM_TXD MODEM_RXD
net GPS_TXD GPS_RXD
net I2C_SDA I2C_SCL
net USB_TXD USB_RXD
net ONEWIRE HALL_INT ADC_BATT

# ── U4 ESP32-WROOM-32E-H4 ────────────────────────────────────────────────────
comp U4 RF_Module:ESP32-WROOM-32E "ESP32-WROOM-32E-H4" @ 124,100 rot 0
  props {
    prop "footprint":"RF_Module:ESP32-WROOM-32E"
    prop "MPN":"ESP32-WROOM-32E-H4"
    prop "Manufacturer":"Espressif"
    prop "LCSC":"C3013935"
  }
  pins (
    1=GND,
    2=V3V3,
    3=ESP_EN,
    4=ADC_BATT,
    5=DNC,
